# DokuKit backend environment example
# Copy this file to .env and replace placeholder values with your own.

# AI services
# Optional. Leave blank to use the local embedding fallback defined in code.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Session and auth settings
SESSION_COOKIE_NAME=dokukit_session
SESSION_MAX_AGE_DAYS=30
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=YOUR_PUBLIC_DOMAIN

# Rate limits
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_ATTEMPTS=10
SIGN_UP_RATE_LIMIT_WINDOW_SECONDS=3600
SIGN_UP_RATE_LIMIT_ATTEMPTS=5
QUERY_RATE_LIMIT_WINDOW_SECONDS=60
QUERY_RATE_LIMIT_ATTEMPTS=60
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=600
UPLOAD_RATE_LIMIT_ATTEMPTS=12

# Request and storage limits
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_QUESTION_LENGTH=5000
MAX_NOTE_LENGTH=20000
MAX_NOTEBOOK_TITLE_LENGTH=160

# App environment
ENVIRONMENT=development
PORT=8000
DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME
FRONTEND_BASE_URL=http://127.0.0.1:3000

# Storage paths
FAISS_INDEX_PATH=./data/faiss/index.bin
PDF_UPLOAD_DIR=./data/uploads/
